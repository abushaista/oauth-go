# PostgreSQL Configuration
DATABASE_URL=postgres://oauth_user:oauth_password@localhost:5432/oauth_db?sslmode=disable

# Server Configuration
PORT=8080

# JWT Configuration (Future)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Session Configuration
SESSION_TIMEOUT=3600
REFRESH_TOKEN_TIMEOUT=604800

# OAuth Configuration
OAUTH_CODE_LIFETIME=600
OAUTH_TOKEN_LIFETIME=3600

# CORS Configuration (Future)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info
